models:
    User: { username: 'string nullable', name: string, email: 'string nullable', email_verified_at: 'datetime nullable', password: 'string nullable', app_authentication_secret: 'text nullable', remember_token: 'string nullable', ldap_domain: 'string nullable', ldap_guid: 'string nullable', employee_id: 'string nullable', department: 'string nullable', title: 'string nullable', manager_dn: 'string nullable', bio_readonly: "boolean default:'0'" }
    Support\Sync\ApiConfig: { name: 'string unique index', source_type: string, source_config: json, data_path: 'string nullable', depends_on: 'json nullable', mapping: json, active: 'boolean default:true index', relationships: { hasMany: ApiData } }
    Support\Sync\ApiData: { api_config_id: 'id foreign:api_configs cascadeOnDelete', fingerprint: 'string nullable index', payload: json, status: 'string default:pending index', processed_at: 'timestamp nullable', error: 'text nullable' }
    Support\AuditTrail\AuditLog: { user_id: 'id nullable foreign:users', staff_id: 'id nullable foreign:staff', result: 'string nullable', actor: string, action: string, reason: 'string nullable', metadata: 'json nullable', relationships: { morphTo: ref } }
    Support\Copies\Versionable: { type: 'enum:document,workflow,template,service,config,other', name: string, current_version_id: 'id nullable foreign:versions', attributes: 'json nullable', relationships: { morphTo: ref, hasMany: Version } }
    Support\Copies\Version: { versionable_id: 'id foreign:versionables', created_by: 'id nullable foreign:staff', approved_by: 'id nullable foreign:staff', published_by: 'id nullable foreign:staff', status: 'enum:draft,approved,published,archived,rejected', content_type: 'enum:file,url,inline,json nullable', content_path: 'string nullable', major: integer, minor: integer, patch: integer, version: string, change_summary: 'string nullable', change_notes: 'text nullable', is_menu: boolean, approved_at: 'timestamp nullable', published_at: 'timestamp nullable', effective_from: 'timestamp nullable', effective_to: 'timestamp nullable', attributes: 'json nullable', relationships: { hasMany: 'VersionApproval, VersionRelation:relations, VersionRelation:relatedRelations' } }
    Support\Copies\VersionApproval: { version_id: 'id foreign:versions', user_id: 'id foreign:staff' }
    Support\Copies\VersionRelation: { version_id: 'id foreign:versions', related_version_id: 'id foreign:versions' }
    Support\Copies\VersionLock: { version_id: 'id foreign:versions', locked_by: 'id foreign:staff' }
    Support\FloorPlan\Location: { parent_id: 'id nullable foreign:locations', org_corp_id: 'id nullable foreign:org_corps', type: 'enum:site,building,area,section,room,zone,other nullable', name: string, attributes: 'json nullable', relationships: { hasMany: 'Location:children, LocationAssignment' } }
    Support\FloorPlan\LocationAssignment: { location_id: 'id foreign:locations', type: 'enum:primary,secondary,temporary nullable', start_date: 'date nullable', end_date: 'date nullable', attributes: 'json nullable', relationships: { morphTo: assignable } }
    Support\Legal\ContractType: { uuid: 'uuid unique', name: string, code: 'string unique', description: 'text nullable', template: 'longtext nullable', public_schema: 'json nullable', confidential_schema: 'json nullable', notify: 'json nullable', expiry_notify_days: 'integer default:30', requires_approval: 'boolean default:false', requires_signature: 'boolean default:false', workflow_id: 'id nullable foreign:workflows', meta: 'json nullable', relationships: { hasMany: Contract } }
    Support\Legal\Contract: { uuid: 'uuid unique', contract_type_id: 'id foreign:contract_types', org_corp_id: 'id nullable foreign:org_corps', contract_no: 'string nullable', title: string, summary: 'text nullable', start_date: 'date nullable', end_date: 'date nullable', renewal_date: 'date nullable', status: 'enum:draft,pending,active,expired,terminated,archived default:draft', terms: 'json nullable', meta: 'json nullable', relationships: { morphTo: contractable, hasOne: ContractConfidentiality, hasMany: ContractParty } }
    Support\Legal\ContractParty: { contract_id: 'id foreign:contracts', role: 'string nullable', is_signatory: 'boolean default:false', notify_on_expiry: 'boolean default:true', meta: 'json nullable', relationships: { morphTo: Party } }
    Support\Legal\ContractConfidentiality: { contract_id: 'id foreign:contracts unique', payload: hashed, allowed_roles: 'json nullable', meta: 'json nullable' }
    Support\Todo\Task: { role_id: 'id nullable foreign:roles', staff_id: 'id nullable foreign:staff', task_list_id: 'id nullable foreign:task_lists', title: string, description: 'text nullable', relationships: { morphTo: ref, hasMany: TaskAssignment, belongsTo: \Spatie\Permission\Models\Role } }
    Support\Todo\TaskList: { name: string, relationships: { hasMany: Task, morphTo: ref } }
    Support\Todo\TaskTemplate: { role_id: 'id nullable foreign:roles', name: string, relationships: { hasMany: TaskListTemplateItem, belongsTo: \Spatie\Permission\Models\Role } }
    Support\Todo\TaskListTemplate: { name: string, relationships: { hasMany: TaskListTemplateItem } }
    Support\Todo\TaskListTemplateItem: { task_list_template_id: 'id foreign:task_list_templates', task_template_id: 'id foreign:task_templates', depends_on_id: 'id nullable foreign:task_list_template_items', relationships: { hasMany: 'TaskListTemplateItem:dependents' } }
    Support\Todo\TaskAssignment: { task_id: 'id foreign:tasks', role_id: 'id nullable foreign:roles', staff_id: 'id nullable foreign:staff', assigned_by: 'id nullable foreign:staff', relationships: { belongsTo: \Spatie\Permission\Models\Role } }
    Support\Schedule\Event: { org_corp_id: 'id nullable foreign:org_corps', org_unit_id: 'id nullable foreign:org_units', org_team_id: 'id nullable foreign:org_teams', type: 'enum:holiday,company,operational,training,maintenance,other', name: string, description: 'text nullable', start_at: timestamp, end_at: 'timestamp nullable', is_blocking: 'boolean default:false', attributes: 'json nullable' }
    Org\OrgCorp: { name: string, code: 'string unique', type: 'enum:company,government,vendor,institution nullable', attributes: 'json nullable', relationships: { hasMany: OrgUnit } }
    Org\OrgUnit: { org_corp_id: 'id foreign:org_corps', parent_id: 'id nullable foreign:org_units', name: string, code: 'string nullable', description: 'string nullable', attributes: 'json nullable', relationships: { hasMany: 'OrgUnit:children, OrgTeam' } }
    Org\OrgTeam: { org_unit_id: 'id foreign:org_units', name: string, code: 'string nullable', is_active: 'boolean default:true', attributes: 'json nullable', relationships: { hasMany: 'Workflow, JobContract' } }
    Job\JobContract: { name: string, org_unit_id: 'id nullable foreign:org_units', org_team_id: 'id nullable foreign:org_teams', type: 'enum:permanent,contract,temporary,outsource nullable', status: 'enum:draft,active,on_hold,closed default:active', position_limit: 'integer nullable', start_date: 'date nullable', end_date: 'date nullable', attributes: 'json nullable', relationships: { hasMany: JobPosition } }
    Job\JobPosition: { job_contract_id: 'id foreign:job_contracts', level: 'enum:junior,mid,senior,lead,manager nullable', status: 'enum:open,filled,closed default:open', title: string, description: 'text nullable', attributes: 'json nullable', relationships: { hasMany: StaffPosition } }
    Job\JobRole: { type: 'enum:approval,operation,admin,reporting nullable', name: string, description: 'text nullable', attributes: 'json nullable' }
    Job\JobPositionRole: { job_position_id: 'id foreign:job_positions', job_role_id: 'id foreign:job_roles' }
    Ppl\Staff: { user_id: 'id nullable foreign:users', org_unit_id: 'id nullable foreign:org_units', job_contract_id: 'id nullable foreign:job_contracts', type: 'enum:internal,external,contractor default:internal', status: 'enum:active,inactive,suspended default:active', name: 'string nullable', staff_no: 'string nullable', attributes: 'json nullable', relationships: { hasMany: 'StaffPosition, Request', morphMany: 'AuditLog:model' } }
    Ppl\StaffPosition: { staff_id: 'id foreign:staff', job_position_id: 'id foreign:job_positions', assignment_type: 'enum:primary,secondary,acting default:primary', status: 'enum:active,ended,pending default:active', start_date: date, end_date: 'date nullable', attributes: 'json nullable' }
    Ppl\Movement: { type: 'enum:transfer,promotion,demotion,assignment,end_of_assignment', effective_date: date, from: 'json nullable', to: 'json nullable', relationships: { morphTo: movable } }
    AuthZ\StaffRole: { staff_id: 'id foreign:staff', role_id: 'id foreign:roles', org_corp_id: 'id nullable foreign:org_corps', org_unit_id: 'id nullable foreign:org_units', org_team_id: 'id nullable foreign:org_teams', job_position_id: 'id nullable foreign:job_positions', job_role_id: 'id nullable foreign:job_roles', job_contract_id: 'id nullable foreign:job_contracts', source: 'enum:auto,manual default:auto', status: 'enum:active,inactive default:active', start_date: 'date nullable', end_date: 'date nullable', attributes: 'json nullable', relationships: { belongsTo: \Spatie\Permission\Models\Role } }
    AuthZ\RoleAssignment: { role_id: 'id foreign:roles', staff_id: 'id foreign:staff', assigned_by: 'id nullable foreign:staff', org_unit_id: 'id nullable foreign:org_units', org_team_id: 'id nullable foreign:org_teams', start_date: 'date nullable', end_date: 'date nullable', attributes: 'json nullable', relationships: { belongsTo: \Spatie\Permission\Models\Role } }
    Calendar\Shift: { org_unit_id: 'id nullable foreign:org_units', org_team_id: 'id nullable foreign:org_teams', staff_id: 'id nullable foreign:staff', type: 'enum:fixed,rotational nullable', name: string, description: 'text nullable', start_time: time, end_time: time, start_date: 'date nullable', end_date: 'date nullable', attributes: 'json nullable' }
    Process\Workflow: { org_team_id: 'id foreign:org_teams', start_step_id: 'id nullable foreign:workflow_steps', name: string, description: 'text nullable', is_active: 'boolean default:true', attributes: 'json nullable', relationships: { hasMany: 'WorkflowStep, WorkflowInstance' } }
    Process\WorkflowStep: { workflow_id: 'id foreign:workflows', type: 'enum:start,process,decision,end default:process', name: string, description: 'text nullable', requires_tasks: 'boolean default:false', requires_decision: 'boolean default:false', is_automatic: 'boolean default:false', attributes: 'json nullable', relationships: { hasMany: 'WorkflowTransition:from_transitions, WorkflowTransition:to_transitions, WorkflowStepTask, WorkflowInstanceStep, WorkflowDecision' } }
    Process\WorkflowTransition: { workflow_id: 'id foreign:workflows', from_step_id: 'id foreign:workflow_steps', to_step_id: 'id foreign:workflow_steps', name: 'string nullable', conditions: 'json nullable', requires_approval: 'boolean default:false', attributes: 'json nullable' }
    Process\WorkflowStepTask: { workflow_step_id: 'id foreign:workflow_steps', task_template_id: 'id nullable foreign:task_templates', task_list_template_id: 'id nullable foreign:task_list_templates', is_required: 'boolean default:true', attributes: 'json nullable' }
    Process\WorkflowInstance: { workflow_id: 'id foreign:workflows', current_step_id: 'id nullable foreign:workflow_steps', status: 'enum:active,completed,cancelled default:active', started_at: 'timestamp nullable', completed_at: 'timestamp nullable', attributes: 'json nullable', relationships: { morphTo: ref, hasMany: 'WorkflowInstanceStep, WorkflowDecision' } }
    Process\WorkflowInstanceStep: { workflow_instance_id: 'id foreign:workflow_instances', workflow_step_id: 'id foreign:workflow_steps', status: 'enum:pending,active,completed,skipped default:pending', started_at: 'timestamp nullable', completed_at: 'timestamp nullable', attributes: 'json nullable' }
    Process\WorkflowDecision: { workflow_instance_id: 'id foreign:workflow_instances', workflow_step_id: 'id foreign:workflow_steps', user_id: 'id foreign:staff', decision: 'enum:approve,reject,request_changes', comment: 'text nullable', decided_at: timestamp, attributes: 'json nullable' }
