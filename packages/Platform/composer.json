{
    "name": "bit-es/platform",
    "description": "Platform package for the BITES.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "BIT Ecosystem",
            "email": "bit.ecosystem@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "autoload": {
        "psr-4": {
            "Bites\\Platform\\": "src/",
            "Bites\\Platform\\Utility\\": "util/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bites\\Platform\\PlatformServiceProvider",
                "Bites\\Platform\\UI\\Panel\\AdminPanelProvider",
                "Bites\\Platform\\UI\\Panel\\StaffPanelProvider"
            ]
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}