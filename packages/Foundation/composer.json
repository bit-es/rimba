{
    "name": "bit-es/foundation",
    "description": "Foundation package for the BITES.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "BIT Ecosystem",
            "email": "bit.ecosystem@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "bit-es/platform": "*",
        "bit-es/support": "*"
    },
    "autoload": {
        "psr-4": {
            "Bites\\Foundation\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bites\\Foundation\\FoundationServiceProvider"
            ]
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}